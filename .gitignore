# Persistent runtime data (default ignored)
data/**
!data/

# Track source-of-truth infra configs that live under data/
!data/cloudflared/
data/cloudflared/**
!data/cloudflared/config.yml
!data/cloudflared/.gitignore


# Local environment and secrets
.env
.env.*
!.env.example

# Legacy leftovers not part of tracked config
arr/

# Local artifacts
*.tar
*.tar.gz
*.tmp
*.swp
