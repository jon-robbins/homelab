# Python artifacts
__pycache__/
*.py[cod]
.venv/
src/homelab_workers/.venv/
.coverage
# Persistent runtime data (default ignored)
data/**
!data/

# Track source-of-truth infra configs that live under data/
!data/cloudflared/
data/cloudflared/**
!data/cloudflared/.gitignore
!data/cloudflared/README.md
!data/cloudflared/config.yml.example

!data/dashy/
data/dashy/**
!data/dashy/conf.yml.example


# Local environment and secrets
.env
.env.*
!.env.example

# Local artifacts
*.tar
*.tar.gz
*.tmp
*.swp
*.bak
*.bak.*

# Local helper binaries downloaded by bootstrap (gum/cloudflared)
bin/
