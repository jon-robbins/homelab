# Python artifacts
__pycache__/
*.py[cod]
.venv/
src/homelab_workers/.venv/
src/homelab_workers/.venv-tests/
.coverage
.pytest_cache/
**/.pytest_cache/
# Persistent runtime data (default ignored)
data/**
!data/

# Track source-of-truth infra configs that live under data/
!data/cloudflared/
data/cloudflared/**
!data/cloudflared/.gitignore
!data/cloudflared/README.md

!data/dashy/
data/dashy/**

!data/openclaw/
data/openclaw/**
!data/openclaw/config/openclaw.json.example

# Local environment and secrets
.env
.env.*
!.env.example

# Local artifacts
*.tar
*.tar.gz
*.tmp
*.swp
*.bak
*.bak.*
*.log
logs/

# Local helper binaries downloaded by bootstrap (gum/cloudflared)
bin/
