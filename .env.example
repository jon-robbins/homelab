# Core runtime identity
PUID=1000
PGID=1000
TZ=UTC

# Routing contract
BASE_DOMAIN=home.ashorkqueen.xyz
CADDY_IMAGE=local/caddy-cf:latest
CADDY_INGRESS_NETWORKS=homelab_net
PIHOLE_WEB_PORT=8083

# Runtime config file paths + canonical templates under config/
DASHY_CONFIG_PATH=./data/dashy/conf.yml
DASHY_CONFIG_TEMPLATE=./config/dashy/conf.yml.example
CLOUDFLARED_CONFIG_PATH=./data/cloudflared/config.yml
CLOUDFLARED_CONFIG_TEMPLATE=./config/cloudflared/config.yml.example

# Host media paths
MEDIA_HDD_PATH=/mnt/media-hdd
MEDIA_NVME_PATH=/mnt/media-nvme
PLEX_DATA_PATH=/srv/plex

# Secrets (set in local .env, keep blank in example)
CLOUDFLARE_TOKEN=
