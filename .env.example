PUID=1000
PGID=1000
TZ=Europe/Madrid

# Pi-hole (DNS sinkhole)
# NOTE: If you run Pi-hole in host networking mode (default in this repo),
# the host must not already be listening on port 53 (often `systemd-resolved`).
# Admin UI password (leave empty to have it randomized on first start; check container logs).
# PIHOLE_WEBPASSWORD=
# Upstream resolvers, semicolon-separated. Defaults to Cloudflare.
# PIHOLE_DNS_=1.1.1.1;1.0.0.1
# Optional: change the Pi-hole web UI port (default 8083; :80 is often taken by Caddy).
# PIHOLE_WEB_PORT=8083

#
# Optional network/proxy settings (deprecated)
# This repo previously supported a GCP tinyproxy + SSH tunnel for Prowlarr egress.
# That setup has been removed as part of slimming down the stack.

# Optional Arr API settings for retry script.
# If set, scripts/workers/retry-sonarr-stalled-downloads.py will use these first.
# SONARR_URL=http://sonarr:8989/sonarr
# SONARR_API_KEY=
# RADARR_URL=http://radarr:7878
# RADARR_API_KEY=
# READARR_URL=http://readarr:8787/readarr
# READARR_API_KEY=
# Internal container-network overrides for worker containers (bridge migration safe defaults).
# SONARR_INTERNAL_URL=http://sonarr:8989/sonarr
# RADARR_INTERNAL_URL=http://radarr:7878/radarr

# Optional qBittorrent settings for health-aware retry mode.
# QBITTORRENT_URL=http://qbittorrent:8080
# QBITTORRENT_USERNAME=
# QBITTORRENT_PASSWORD=
# QBITTORRENT_INTERNAL_URL=http://qbittorrent:8080

# Optional health policy tuning (defaults shown).
# ARR_HEALTH_STATE_FILE=/workspace/data/arr-retry/health_state.json
# ARR_HEALTH_REPLACE_AGE_HOURS=12
# ARR_HEALTH_RACE_AGE_HOURS=36
# ARR_HEALTH_MIN_AVG_SPEED_KIB=10
# ARR_HEALTH_SKIP_PROGRESS_PERCENT=95
# ARR_HEALTH_COOLDOWN_HOURS=12
# ARR_HEALTH_MAX_REPLACEMENTS_PER_DAY=2
# ARR_HEALTH_MAX_ACTIONS_PER_SWEEP=8
# ARR_HEALTH_MIN_SEEDERS=1

# Optional manual UI for stuck torrents (internal-only service).
# ARR_HEALTH_UI_HOST=127.0.0.1
# ARR_HEALTH_UI_PORT=8091
# Torrent Health UI: wait for /release after EpisodeSearch/MoviesSearch (seconds)
# ARR_UI_RELEASE_WAIT_SECONDS=60
# ARR_UI_RELEASE_POLL_SECONDS=2.5
# ARR_HEALTH_LOG_FILE=/workspace/data/arr-retry/health-last-run.log
# arr-retry-worker: stalled Sonarr-category torrents with no Sonarr queue -> EpisodeSearch + qB delete
# ARR_RETRY_QBT_ORPHAN_STALLS=true
# SONARR_QBT_CATEGORY=tv-sonarr
# ARR_RETRY_MAX_QB_ORPHANS=10
# ARR_RETRY_QBT_ORPHAN_MIN_AGE_SECONDS=3600
# Monitored missing with empty /release cache still trigger indexer search
# ARR_RETRY_MISSING_EMPTY_RELEASE_SEARCH=true
