# Core runtime identity
PUID=1000
PGID=1000
TZ=UTC

# Routing contract
# Used by Caddyfile for site addresses and by Compose for service config
BASE_DOMAIN=home.ashorkqueen.xyz
CADDY_IMAGE=local/caddy-cf:latest

# Runtime config file paths + canonical templates under config/
DASHY_CONFIG_PATH=./data/dashy/conf.yml
DASHY_CONFIG_TEMPLATE=./config/dashy/conf.yml.example
CLOUDFLARED_CONFIG_PATH=./data/cloudflared/config.yml
CLOUDFLARED_CONFIG_TEMPLATE=./config/cloudflared/config.yml.example

# Host media paths
MEDIA_HDD_PATH=/mnt/media-hdd
MEDIA_NVME_PATH=/mnt/media-nvme
PLEX_DATA_PATH=/srv/plex

# Pi-hole (DNS)
PIHOLE_WEBPASSWORD=
PIHOLE_WEB_PORT=8083

# Arr stack API keys (generated by each app on first run)
SONARR_API_KEY=
RADARR_API_KEY=
READARR_API_KEY=
BAZARR_API_KEY=
PROWLARR_API_KEY=

# qBittorrent
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=

# VPN sidecar for qBittorrent (gluetun)
VPN_SERVICE_PROVIDER=
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
SERVER_COUNTRIES=

# OpenClaw
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_BIND=loopback
TELEGRAM_BOT_TOKEN=

# Media agent
MEDIA_AGENT_TOKEN=

# External API keys
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Secrets (Cloudflare DNS-01 challenge + tunnel auth)
CLOUDFLARE_TOKEN=
